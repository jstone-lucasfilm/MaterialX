<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <nodedef name="ND_mxlogo_halfplane_float" node="mxlogo_halfplane" nodegroup="procedural2d">
    <output name="out" type="float" />
    <input name="uv" type="vector2" />
    <input name="a" type="vector2" />
    <input name="b" type="vector2" />
    <input name="radius" type="float" value="0" />
    <input name="softness" type="float" value="0.0008" />
  </nodedef>
  <nodegraph name="NG_mxlogo_halfplane_float" nodedef="ND_mxlogo_halfplane_float">
    <subtract name="edge" type="vector2">
      <input name="in1" type="vector2" interfacename="b" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <separate2 name="esep" type="multioutput">
      <input name="in" type="vector2" nodename="edge" />
    </separate2>
    <multiply name="negy" type="float">
      <input name="in1" type="float" nodename="esep" output="outy" />
      <input name="in2" type="float" value="-1" />
    </multiply>
    <combine2 name="normal" type="vector2">
      <input name="in1" type="float" nodename="negy" />
      <input name="in2" type="float" nodename="esep" output="outx" />
    </combine2>
    <normalize name="nnorm" type="vector2">
      <input name="in" type="vector2" nodename="normal" />
    </normalize>
    <subtract name="rel" type="vector2">
      <input name="in1" type="vector2" interfacename="uv" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <dotproduct name="sdist" type="float">
      <input name="in1" type="vector2" nodename="rel" />
      <input name="in2" type="vector2" nodename="nnorm" />
    </dotproduct>
    <add name="soff" type="float">
      <input name="in1" type="float" nodename="sdist" />
      <input name="in2" type="float" interfacename="radius" />
    </add>
    <multiply name="nsoft" type="float">
      <input name="in1" type="float" interfacename="softness" />
      <input name="in2" type="float" value="-1" />
    </multiply>
    <smoothstep name="cov" type="float">
      <input name="in" type="float" nodename="soff" />
      <input name="low" type="float" nodename="nsoft" />
      <input name="high" type="float" interfacename="softness" />
    </smoothstep>
    <output name="out" type="float" nodename="cov" />
  </nodegraph>
  <nodedef name="ND_mxlogo_tri_float" node="mxlogo_tri" nodegroup="procedural2d">
    <output name="out" type="float" />
    <input name="uv" type="vector2" />
    <input name="a" type="vector2" />
    <input name="b" type="vector2" />
    <input name="c" type="vector2" />
    <input name="radius" type="float" value="0" />
    <input name="softness" type="float" value="0.0008" />
  </nodedef>
  <nodegraph name="NG_mxlogo_tri_float" nodedef="ND_mxlogo_tri_float">
    <mxlogo_halfplane name="hp0" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="a" />
      <input name="b" type="vector2" interfacename="b" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <mxlogo_halfplane name="hp1" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="b" />
      <input name="b" type="vector2" interfacename="c" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <mxlogo_halfplane name="hp2" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="c" />
      <input name="b" type="vector2" interfacename="a" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <min name="isect1" type="float">
      <input name="in1" type="float" nodename="hp0" />
      <input name="in2" type="float" nodename="hp1" />
    </min>
    <min name="isect2" type="float">
      <input name="in1" type="float" nodename="isect1" />
      <input name="in2" type="float" nodename="hp2" />
    </min>
    <output name="out" type="float" nodename="isect2" />
  </nodegraph>
  <nodedef name="ND_mxlogo_quad_float" node="mxlogo_quad" nodegroup="procedural2d">
    <output name="out" type="float" />
    <input name="uv" type="vector2" />
    <input name="a" type="vector2" />
    <input name="b" type="vector2" />
    <input name="c" type="vector2" />
    <input name="d" type="vector2" />
    <input name="radius" type="float" value="0" />
    <input name="softness" type="float" value="0.0008" />
  </nodedef>
  <nodegraph name="NG_mxlogo_quad_float" nodedef="ND_mxlogo_quad_float">
    <mxlogo_halfplane name="hp0" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="a" />
      <input name="b" type="vector2" interfacename="b" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <mxlogo_halfplane name="hp1" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="b" />
      <input name="b" type="vector2" interfacename="c" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <mxlogo_halfplane name="hp2" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="c" />
      <input name="b" type="vector2" interfacename="d" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <mxlogo_halfplane name="hp3" type="float">
      <input name="uv" type="vector2" interfacename="uv" />
      <input name="a" type="vector2" interfacename="d" />
      <input name="b" type="vector2" interfacename="a" />
      <input name="radius" type="float" interfacename="radius" />
      <input name="softness" type="float" interfacename="softness" />
    </mxlogo_halfplane>
    <min name="isect1" type="float">
      <input name="in1" type="float" nodename="hp0" />
      <input name="in2" type="float" nodename="hp1" />
    </min>
    <min name="isect2" type="float">
      <input name="in1" type="float" nodename="isect1" />
      <input name="in2" type="float" nodename="hp2" />
    </min>
    <min name="isect3" type="float">
      <input name="in1" type="float" nodename="isect2" />
      <input name="in2" type="float" nodename="hp3" />
    </min>
    <output name="out" type="float" nodename="isect3" />
  </nodegraph>
  <nodedef name="ND_mxlogo_stroke_float" node="mxlogo_stroke" nodegroup="procedural2d">
    <output name="out" type="float" />
    <input name="uv" type="vector2" />
    <input name="a" type="vector2" />
    <input name="b" type="vector2" />
    <input name="radius" type="float" value="0.002" />
    <input name="softness" type="float" value="0.0008" />
  </nodedef>
  <nodegraph name="NG_mxlogo_stroke_float" nodedef="ND_mxlogo_stroke_float">
    <subtract name="edge" type="vector2">
      <input name="in1" type="vector2" interfacename="b" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <subtract name="rel" type="vector2">
      <input name="in1" type="vector2" interfacename="uv" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <dotproduct name="wdote" type="float">
      <input name="in1" type="vector2" nodename="rel" />
      <input name="in2" type="vector2" nodename="edge" />
    </dotproduct>
    <dotproduct name="edote" type="float">
      <input name="in1" type="vector2" nodename="edge" />
      <input name="in2" type="vector2" nodename="edge" />
    </dotproduct>
    <divide name="traw" type="float">
      <input name="in1" type="float" nodename="wdote" />
      <input name="in2" type="float" nodename="edote" />
    </divide>
    <clamp name="tclamp" type="float">
      <input name="in" type="float" nodename="traw" />
    </clamp>
    <multiply name="eoff" type="vector2">
      <input name="in1" type="vector2" nodename="edge" />
      <input name="in2" type="float" nodename="tclamp" />
    </multiply>
    <add name="proj" type="vector2">
      <input name="in1" type="vector2" interfacename="a" />
      <input name="in2" type="vector2" nodename="eoff" />
    </add>
    <subtract name="dvec" type="vector2">
      <input name="in1" type="vector2" interfacename="uv" />
      <input name="in2" type="vector2" nodename="proj" />
    </subtract>
    <magnitude name="dist" type="float">
      <input name="in" type="vector2" nodename="dvec" />
    </magnitude>
    <subtract name="rlo" type="float">
      <input name="in1" type="float" interfacename="radius" />
      <input name="in2" type="float" interfacename="softness" />
    </subtract>
    <add name="rhi" type="float">
      <input name="in1" type="float" interfacename="radius" />
      <input name="in2" type="float" interfacename="softness" />
    </add>
    <smoothstep name="falloff" type="float">
      <input name="in" type="float" nodename="dist" />
      <input name="low" type="float" nodename="rlo" />
      <input name="high" type="float" nodename="rhi" />
    </smoothstep>
    <subtract name="cov" type="float">
      <input name="in1" type="float" value="1" />
      <input name="in2" type="float" nodename="falloff" />
    </subtract>
    <output name="out" type="float" nodename="cov" />
  </nodegraph>
  <nodedef name="ND_mxlogo_lineargrad_float" node="mxlogo_lineargrad" nodegroup="procedural2d">
    <output name="out" type="float" />
    <input name="uv" type="vector2" />
    <input name="a" type="vector2" />
    <input name="b" type="vector2" />
  </nodedef>
  <nodegraph name="NG_mxlogo_lineargrad_float" nodedef="ND_mxlogo_lineargrad_float">
    <subtract name="axis" type="vector2">
      <input name="in1" type="vector2" interfacename="b" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <subtract name="rel" type="vector2">
      <input name="in1" type="vector2" interfacename="uv" />
      <input name="in2" type="vector2" interfacename="a" />
    </subtract>
    <dotproduct name="wdote" type="float">
      <input name="in1" type="vector2" nodename="rel" />
      <input name="in2" type="vector2" nodename="axis" />
    </dotproduct>
    <dotproduct name="edote" type="float">
      <input name="in1" type="vector2" nodename="axis" />
      <input name="in2" type="vector2" nodename="axis" />
    </dotproduct>
    <divide name="traw" type="float">
      <input name="in1" type="float" nodename="wdote" />
      <input name="in2" type="float" nodename="edote" />
    </divide>
    <clamp name="tclamp" type="float">
      <input name="in" type="float" nodename="traw" />
    </clamp>
    <output name="out" type="float" nodename="tclamp" />
  </nodegraph>
  <nodedef name="ND_materialx_logo_color4" node="materialx_logo" nodegroup="procedural2d" doc="Procedural rendition of the MaterialX logo glyph. Output is unpremultiplied RGBA; alpha is glyph coverage.">
    <output name="out" type="color4" />
    <input name="texcoord" type="vector2" defaultgeomprop="UV0" />
    <input name="center" type="vector2" value="0.5, 0.5" />
    <input name="size" type="float" value="0.9" />
    <input name="softness" type="float" value="0.0008" />
    <input name="linewidth" type="float" value="0.0028" />
  </nodedef>
  <nodegraph name="NG_materialx_logo_color4" nodedef="ND_materialx_logo_color4">
    <subtract name="centered" type="vector2">
      <input name="in1" type="vector2" interfacename="texcoord" />
      <input name="in2" type="vector2" interfacename="center" />
    </subtract>
    <divide name="p" type="vector2">
      <input name="in1" type="vector2" nodename="centered" />
      <input name="in2" type="float" interfacename="size" />
    </divide>
    <multiply name="line_radius" type="float">
      <input name="in1" type="float" interfacename="linewidth" />
      <input name="in2" type="float" value="0.5" />
    </multiply>
    <mxlogo_quad name="mask_slash" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="-0.333333, -0.288675" />
      <input name="b" type="vector2" value="0.333333, 0.096225" />
      <input name="c" type="vector2" value="0.333333, 0.288675" />
      <input name="d" type="vector2" value="-0.333333, -0.096225" />
    </mxlogo_quad>
    <mxlogo_quad name="mask_bandu" type="float">
      <input name="uv" type="vector2" nodename="p" />
