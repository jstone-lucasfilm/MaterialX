      <input name="a" type="vector2" value="0, -0.096225" />
      <input name="b" type="vector2" value="0.166667, 0" />
      <input name="c" type="vector2" value="0, 0.096225" />
      <input name="d" type="vector2" value="-0.166667, 0" />
    </mxlogo_quad>
    <mxlogo_quad name="mask_bandl" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="0.166667, -0.19245" />
      <input name="b" type="vector2" value="0.333333, -0.096225" />
      <input name="c" type="vector2" value="0.166667, 0" />
      <input name="d" type="vector2" value="0, -0.096225" />
    </mxlogo_quad>
    <mxlogo_tri name="mask_smalltri" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="0.166667, -0.19245" />
      <input name="b" type="vector2" value="0.333333, -0.288675" />
      <input name="c" type="vector2" value="0.333333, -0.096225" />
    </mxlogo_tri>
    <mxlogo_quad name="mask_cube" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="0.333333, -0.288675" />
      <input name="b" type="vector2" value="0.5, -0.19245" />
      <input name="c" type="vector2" value="0.5, 0.19245" />
      <input name="d" type="vector2" value="0.333333, 0.288675" />
    </mxlogo_quad>
    <mxlogo_quad name="mask_pink1" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="-0.5, 0.19245" />
      <input name="b" type="vector2" value="-0.5, -0.19245" />
      <input name="c" type="vector2" value="-0.333333, -0.288675" />
      <input name="d" type="vector2" value="-0.333333, 0.288675" />
    </mxlogo_quad>
    <mxlogo_quad name="mask_pink2" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="softness" type="float" interfacename="softness" />
      <input name="a" type="vector2" value="-0.333333, 0.096225" />
      <input name="b" type="vector2" value="-0.166667, 0" />
      <input name="c" type="vector2" value="0, 0.096225" />
      <input name="d" type="vector2" value="-0.333333, 0.288675" />
    </mxlogo_quad>
    <constant name="c_pink" type="color3">
      <input name="value" type="color3" value="0.839216, 0.258824, 0.454902" colorspace="srgb_texture" />
    </constant>
    <constant name="c_dpink" type="color3">
      <input name="value" type="color3" value="0.741176, 0.160784, 0.356863" colorspace="srgb_texture" />
    </constant>
    <constant name="c_slash_mid" type="color3">
      <input name="value" type="color3" value="0.0431373, 0.470588, 0.556863" colorspace="srgb_texture" />
    </constant>
    <constant name="c_slash_end" type="color3">
      <input name="value" type="color3" value="0.0196078, 0.364706, 0.423529" colorspace="srgb_texture" />
    </constant>
    <constant name="c_bandu" type="color3">
      <input name="value" type="color3" value="0.25098, 0.380392, 0.521569" colorspace="srgb_texture" />
    </constant>
    <constant name="c_bandl_a" type="color3">
      <input name="value" type="color3" value="0.196078, 0.380392, 0.513726" colorspace="srgb_texture" />
    </constant>
    <constant name="c_bandl_b" type="color3">
      <input name="value" type="color3" value="0.145098, 0.435294, 0.537255" colorspace="srgb_texture" />
    </constant>
    <constant name="c_smalltri" type="color3">
      <input name="value" type="color3" value="0.0431373, 0.478431, 0.564706" colorspace="srgb_texture" />
    </constant>
    <constant name="c_cube_bot" type="color3">
      <input name="value" type="color3" value="0, 0.407843, 0.478431" colorspace="srgb_texture" />
    </constant>
    <constant name="c_cube_top" type="color3">
      <input name="value" type="color3" value="0.0862745, 0.698039, 0.803922" colorspace="srgb_texture" />
    </constant>
    <constant name="c_cube_hl" type="color3">
      <input name="value" type="color3" value="0.521569, 0.827451, 0.890196" colorspace="srgb_texture" />
    </constant>
    <constant name="c_seam_pink" type="color3">
      <input name="value" type="color3" value="1, 0.8, 0.8" colorspace="srgb_texture" />
    </constant>
    <constant name="c_seam_cyan" type="color3">
      <input name="value" type="color3" value="0.701961, 0.878431, 0.87451" colorspace="srgb_texture" />
    </constant>
    <mxlogo_lineargrad name="slash_t" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="a" type="vector2" value="-0.333333, -0.19245" />
      <input name="b" type="vector2" value="0.333333, 0.19245" />
    </mxlogo_lineargrad>
    <multiply name="slash_t2" type="float">
      <input name="in1" type="float" nodename="slash_t" />
      <input name="in2" type="float" value="2" />
    </multiply>
    <subtract name="slash_tc" type="float">
      <input name="in1" type="float" nodename="slash_t2" />
      <input name="in2" type="float" value="1" />
    </subtract>
    <absval name="slash_ta" type="float">
      <input name="in" type="float" nodename="slash_tc" />
    </absval>
    <multiply name="slash_tg" type="float">
      <input name="in1" type="float" nodename="slash_ta" />
      <input name="in2" type="float" value="1.568" />
    </multiply>
    <subtract name="slash_ts" type="float">
      <input name="in1" type="float" nodename="slash_tg" />
      <input name="in2" type="float" value="0.568" />
    </subtract>
    <clamp name="slash_td" type="float">
      <input name="in" type="float" nodename="slash_ts" />
    </clamp>
    <mix name="col_slash" type="color3">
      <input name="fg" type="color3" nodename="c_slash_end" />
      <input name="bg" type="color3" nodename="c_slash_mid" />
      <input name="mix" type="float" nodename="slash_td" />
    </mix>
    <mxlogo_lineargrad name="bandl_t" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="a" type="vector2" value="0.0833333, -0.0481125" />
      <input name="b" type="vector2" value="0.25, -0.144338" />
    </mxlogo_lineargrad>
    <mix name="col_bandl" type="color3">
      <input name="fg" type="color3" nodename="c_bandl_b" />
      <input name="bg" type="color3" nodename="c_bandl_a" />
      <input name="mix" type="float" nodename="bandl_t" />
    </mix>
    <mxlogo_lineargrad name="cube_t" type="float">
      <input name="uv" type="vector2" nodename="p" />
      <input name="a" type="vector2" value="-0.028621, -0.0696486" />
      <input name="b" type="vector2" value="0.110797, 0.269622" />
    </mxlogo_lineargrad>
    <mix name="col_cubebase" type="color3">
      <input name="fg" type="color3" nodename="c_cube_top" />
      <input name="bg" type="color3" nodename="c_cube_bot" />
      <input name="mix" type="float" nodename="cube_t" />
    </mix>
    <subtract name="cube_hvec" type="vector2">
      <input name="in1" type="vector2" nodename="p" />
      <input name="in2" type="vector2" value="0.4866, 0.1525" />
    </subtract>
    <rotate2d name="cube_hrot" type="vector2">
      <input name="in" type="vector2" nodename="cube_hvec" />
      <input name="amount" type="float" value="-30.42" />
    </rotate2d>
    <multiply name="cube_hscale" type="vector2">
      <input name="in1" type="vector2" nodename="cube_hrot" />
      <input name="in2" type="vector2" value="0.844238, 14.5138" />
    </multiply>
    <magnitude name="cube_hdist" type="float">
      <input name="in" type="vector2" nodename="cube_hscale" />
    </magnitude>
    <smoothstep name="cube_hss" type="float">
      <input name="in" type="float" nodename="cube_hdist" />
      <input name="low" type="float" value="0" />
      <input name="high" type="float" value="1" />
    </smoothstep>
    <subtract name="cube_hmask" type="float">
      <input name="in1" type="float" value="1" />
      <input name="in2" type="float" nodename="cube_hss" />
    </subtract>
    <mix name="col_cube" type="color3">
      <input name="fg" type="color3" nodename="c_cube_hl" />
      <input name="bg" type="color3" nodename="col_cubebase" />
      <input name="mix" type="float" nodename="cube_hmask" />
    </mix>
    <constant name="c_black" type="color3">
      <input name="value" type="color3" value="0, 0, 0" />
